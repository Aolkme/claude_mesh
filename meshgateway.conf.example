; meshgateway 配置文件示例
; 复制此文件为 meshgateway.conf 并按需修改

[serial]
; 串口设备路径
; Linux/macOS: /dev/ttyUSB0, /dev/ttyACM0, /dev/cu.usbserial-xxx
; Windows:     COM3, COM4, ...
device = /dev/ttyUSB0
baudrate = 115200
; 断线后重连等待时间（秒）
reconnect_interval = 5

[network]
; TCP IPC 服务器地址（只监听本地连接）
host = 127.0.0.1
port = 9999
; 最大客户端连接数
max_clients = 16

[heartbeat]
; 心跳间隔（秒），Meshtastic固件15分钟超时，建议10分钟
interval = 600
timeout = 30

[log]
; 日志级别: debug, info, warn, error
level = info
; 日志文件路径（留空则只输出控制台）
file = meshgateway.log
; 单个日志文件最大大小（MB）
max_size = 10
; 保留的日志文件数量
max_files = 5

[node]
; 节点过期时间（秒），超过此时间未收到消息则认为节点离线
expire_time = 7200
